# Copy to .env only if you need overrides (file is gitignored as .env).

# --- Local dev (default: Vite proxies /api → http://localhost:8001) ---
# Optional: change proxy target
# VITE_DEV_API_PROXY=http://localhost:8001

# --- Production build (Vercel / CI): set in host dashboard, not only here ---
# Full API origin, NO trailing slash. Required for `npm run build` when API is not same-origin.
# VITE_API_URL=https://your-api.onrender.com
